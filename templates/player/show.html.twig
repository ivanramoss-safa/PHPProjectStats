{% extends 'base.html.twig' %}

{% block title %}{{ player.player.name }} - Perfil{% endblock %}

{% block body %}
<div class="row">
    
    <div class="col-lg-3 mb-4">
        <div class="card border-0 shadow-sm text-center p-4 mb-4">
            <img src="{{ player.player.photo }}" alt="{{ player.player.name }}" class="rounded-circle mx-auto mb-3 shadow-sm" style="width: 120px; height: 120px; object-fit: cover;">
            <h3 class="fw-bold mb-1">{{ player.player.name }}</h3>
            <p class="text-muted mb-3">{{ player.player.firstname }} {{ player.player.lastname }}</p>
            
            <div class="d-flex justify-content-center gap-2 mb-3 align-items-center">
                {% if currentTeam.logo is defined %}
                    <img src="{{ currentTeam.logo }}" class="rounded-circle bg-white shadow-sm p-1" width="50" height="50" title="{{ currentTeam.name }}">
                {% endif %}
                <span class="badge bg-primary align-self-center fs-6 ms-2">{{ player.player.age }} años</span>
                
                {% if averageRating is defined and averageRating > 0 %}
                    <div class="d-flex align-items-center ms-2" title="Valoración media: {{ averageRating|number_format(1) }}">
                        <span class="text-warning me-1">
                            {% for i in 1..5 %}
                                {% if i <= averageRating|round(0, 'floor') %}
                                    <i class="fas fa-star"></i>
                                {% elseif i - averageRating < 0.5 %}
                                    <i class="fas fa-star-half-alt"></i>
                                {% else %}
                                    <i class="far fa-star"></i>
                                {% endif %}
                            {% endfor %}
                        </span>
                        <span class="fw-bold small">({{ averageRating|number_format(1) }})</span>
                    </div>
                {% endif %}
            </div>

            <hr>

            {% if injury is defined and injury %}
                <div class="alert alert-danger border-0 p-2 mb-3 text-center">
                    <span class="fw-bold">🏥 Lesionado</span>
                    {% if injury.reason is defined and injury.reason %}
                        <small class="d-block text-muted">{{ injury.reason }}</small>
                    {% endif %}
                    {% if injury.type is defined and injury.type %}
                        <span class="badge bg-danger">{{ injury.type }}</span>
                    {% endif %}
                </div>
            {% endif %}

            <ul class="list-group list-group-flush text-start small">
                
                <li class="list-group-item d-flex justify-content-between px-0">
                    <span class="text-muted">Nacionalidad</span>
                    <span class="fw-bold">{{ player.player.nationality }}</span>
                </li>
                <li class="list-group-item d-flex justify-content-between px-0">
                    <span class="text-muted">Altura</span>
                    <span class="fw-bold">{{ player.player.height }}</span>
                </li>
                <li class="list-group-item d-flex justify-content-between px-0">
                    <span class="text-muted">Peso</span>
                    <span class="fw-bold">{{ player.player.weight }}</span>
                </li>
            </ul>
        </div>

        
        <div class="card border-0 shadow-sm p-3 mb-4">
            <label class="form-label fw-bold small text-muted text-uppercase">Temporada</label>
            <div class="dropdown">
                <button class="btn btn-outline-secondary w-100 dropdown-toggle d-flex justify-content-between align-items-center" type="button" data-bs-toggle="dropdown">
                    {% if season == 2025 %}⚽ Temporada Actual{% else %}Start {{ season }} - End {{ season + 1 }}{% endif %}
                </button>
                <ul class="dropdown-menu w-100" style="max-height: 300px; overflow-y: auto;">
                    {% for s in seasons %}
                        <li><a class="dropdown-item {% if s == season %}active{% endif %}" href="{{ path('player_show', {'id': player.player.id, 'season': s}) }}">
                            {% if s == 2025 %}⚽ Temporada Actual{% else %}{{ s }} / {{ s + 1 }}{% endif %}
                        </a></li>
                    {% endfor %}
                </ul>
            </div>
        </div>
    </div>

    
    <div class="col-lg-9">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-bottom-0 pb-0">
                <ul class="nav nav-tabs border-bottom-0" id="playerTab" role="tablist">
                    <li class="nav-item">
                        <button class="nav-link active fw-bold" data-bs-toggle="tab" data-bs-target="#stats">
                            📊 Estadísticas {% if season == 2025 %}Temporada Actual{% else %}{{ season }}{% endif %}
                        </button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link fw-bold" data-bs-toggle="tab" data-bs-target="#trophies">
                            🏆 Palmarés
                        </button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link fw-bold" data-bs-toggle="tab" data-bs-target="#transfers">
                            ✈️ Fichajes
                        </button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link fw-bold" data-bs-toggle="tab" data-bs-target="#news">
                            📰 Noticias
                        </button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link fw-bold text-primary" data-bs-toggle="tab" data-bs-target="#forum">
                            💬 Foro
                        </button>
                    </li>
                </ul>
            </div>
            
            <div class="card-body">
                <div class="tab-content" id="playerTabContent">
                    
                    
                    <div class="tab-pane fade show active" id="stats">
                        <h5 class="fw-bold mb-3">Rendimiento Temporada {% if season == 2025 %}Actual (2025/26){% else %}{{ season }}{% endif %}</h5>

                        {% if season == 2025 %}
                            
                            {% if besoccer2025Stats is not null %}
                                {% set ss = besoccer2025Stats.season_stats %}
                                
                                <div class="card border-0 shadow-sm mb-4">
                                    <div class="card-header bg-dark text-white d-flex align-items-center gap-2">
                                        <img src="https://cdn.resfu.com/media/img/league_logos/primera-division-ea.png?size=30x&lossy=1" width="28" height="28" alt="LaLiga">
                                        <strong>Estadísticas 2025/26 · Partidos Oficiales</strong>
                                        <a href="{{ besoccer2025Stats.besoccer_url }}" target="_blank" class="ms-auto text-white-50 small text-decoration-none">
                                            Ver en BeSoccer ↗
                                        </a>
                                    </div>
                                    <div class="card-body">
                                        <div class="row text-center g-3">
                                            <div class="col-4 col-md-2">
                                                <div class="p-3 border rounded bg-light">
                                                    <div class="h3 mb-0 fw-bold text-primary">{{ ss.partidos|default(0) }}</div>
                                                    <small class="text-muted">Partidos</small>
                                                </div>
                                            </div>
                                            <div class="col-4 col-md-2">
                                                <div class="p-3 border rounded bg-light">
                                                    <div class="h3 mb-0 fw-bold text-secondary">{{ ss.minutos|default(0) }}<small style="font-size:0.5em">'</small></div>
                                                    <small class="text-muted">Minutos</small>
                                                </div>
                                            </div>
                                            <div class="col-4 col-md-2">
                                                <div class="p-3 border rounded bg-light">
                                                    <div class="h3 mb-0 fw-bold text-success">{{ ss.goles|default(0) }}</div>
                                                    <small class="text-muted">Goles</small>
                                                </div>
                                            </div>
                                            <div class="col-4 col-md-2">
                                                <div class="p-3 border rounded bg-light">
                                                    <div class="h3 mb-0 fw-bold text-info">{{ ss.asistencias|default(0) }}</div>
                                                    <small class="text-muted">Asistencias</small>
                                                </div>
                                            </div>
                                            <div class="col-4 col-md-2">
                                                <div class="p-3 border rounded bg-light">
                                                    <div class="h3 mb-0 fw-bold">
                                                        <span class="text-warning">{{ ss.amarillas|default(0) }}</span>
                                                        <span class="text-muted small">/</span>
                                                        <span class="text-danger">{{ ss.rojas|default(0) }}</span>
                                                    </div>
                                                    <small class="text-muted">🟨/🟥 Tarjetas</small>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                
                                {% if besoccer2025Stats.last_matches is not empty %}
                                <div class="card border-0 shadow-sm mb-3">
                                    <div class="card-header bg-white border-bottom d-flex align-items-center">
                                        <strong>⚡ Rendimiento en los últimos partidos</strong>
                                    </div>
                                    <div class="card-body p-2">
                                        <div class="d-flex gap-2 overflow-auto pb-1">
                                            {% for match in besoccer2025Stats.last_matches %}
                                                <a href="{{ match.url }}" target="_blank" class="text-decoration-none flex-shrink-0" style="min-width:90px;">
                                                    <div class="border rounded text-center p-2
                                                        {% if match.result == 'win' %}border-success bg-success bg-opacity-10
                                                        {% elseif match.result == 'draw' %}border-warning bg-warning bg-opacity-10
                                                        {% else %}border-danger bg-danger bg-opacity-10{% endif %}">
                                                        {% if match.league_logo %}
                                                            <img src="{{ match.league_logo }}" height="20" class="mb-1" alt="">
                                                        {% endif %}
                                                        <div class="small fw-bold">{{ match.home }} - {{ match.away }}</div>
                                                        <div class="fw-bold fs-6 my-1
                                                            {% if match.result == 'win' %}text-success
                                                            {% elseif match.result == 'draw' %}text-warning
                                                            {% else %}text-danger{% endif %}">
                                                            {{ match.score }}
                                                        </div>
                                                        <div class="text-muted" style="font-size:0.7rem">{{ match.date }}</div>
                                                    </div>
                                                </a>
                                            {% endfor %}
                                        </div>
                                    </div>
                                </div>
                                {% endif %}

                            {% else %}
                                
                                <div class="alert alert-secondary d-flex align-items-center gap-2">
                                    <span style="font-size:1.5rem">⚽</span>
                                    <div>
                                        <strong>Estadísticas 2025/26 no disponibles aún</strong><br>
                                        <small>Los datos de este jugador para la temporada actual aún no han sido recogidos de BeSoccer.
                                        Ejecuta <code>python scrape_besoccer_players.py</code> para actualizarlos.</small>
                                    </div>
                                </div>
                            {% endif %}

                        {% else %}
                            
                            {% for stat in player.statistics %}
                                {% if stat.games.appearences|default(0) > 0 %}
                                <div class="card bg-light border-0 mb-3">
                                    <div class="card-body">
                                        <div class="d-flex align-items-center mb-3 border-bottom pb-2">
                                            <img src="{{ stat.league.logo }}" width="30" class="me-2">
                                            <h6 class="mb-0 fw-bold">{{ stat.league.name }}</h6>
                                            <span class="ms-auto badge bg-dark">{{ stat.team.name }}</span>
                                        </div>
                                        <div class="row text-center">
                                            <div class="col-3 col-md-2 mb-2">
                                                <div class="p-2 border rounded bg-white">
                                                    <div class="h4 mb-0 fw-bold text-primary">{{ stat.games.appearences|default(0) }}</div>
                                                    <small class="text-muted" style="font-size: 0.75rem;">Partidos</small>
                                                </div>
                                            </div>
                                            <div class="col-3 col-md-2 mb-2">
                                                <div class="p-2 border rounded bg-white">
                                                    <div class="h4 mb-0 fw-bold text-success">{{ stat.goals.total|default(0) }}</div>
                                                    <small class="text-muted" style="font-size: 0.75rem;">Goles</small>
                                                </div>
                                            </div>
                                            <div class="col-3 col-md-2 mb-2">
                                                <div class="p-2 border rounded bg-white">
                                                    <div class="h4 mb-0 fw-bold text-info">{{ stat.goals.assists|default(0) }}</div>
                                                    <small class="text-muted" style="font-size: 0.75rem;">Asistencias</small>
                                                </div>
                                            </div>
                                            <div class="col-3 col-md-2 mb-2">
                                                <div class="p-2 border rounded bg-white">
                                                    <div class="h4 mb-0 fw-bold text-warning">{{ stat.games.minutes|default(0) }}</div>
                                                    <small class="text-muted" style="font-size: 0.75rem;">Minutos</small>
                                                </div>
                                            </div>
                                            <div class="col-3 col-md-2 mb-2">
                                                <div class="p-2 border rounded bg-white">
                                                    <div class="h4 mb-0 fw-bold text-secondary">{{ stat.games.rating|default('-')|slice(0,4) }}</div>
                                                    <small class="text-muted" style="font-size: 0.75rem;">Rating</small>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                {% endif %}
                            {% endfor %}
                        {% endif %}
                    </div>

                    
                    <div class="tab-pane fade" id="trophies">
                        {% if trophies is empty %}
                            <p class="text-muted text-center py-4">Sin títulos registrados.</p>
                        {% else %}
                            <div class="row row-cols-1 row-cols-md-2 g-3">
                                {% for trophy in trophies %}
                                    <div class="col">
                                        <div class="d-flex align-items-center p-3 border rounded">
                                            <i class="fas fa-trophy text-warning fs-3 me-3"></i>
                                            <div>
                                                <div class="fw-bold">{{ trophy.league }}</div>
                                                <div class="text-muted small">{{ trophy.season }} - {{ trophy.place }}</div>
                                            </div>
                                        </div>
                                    </div>
                                {% endfor %}
                            </div>
                        {% endif %}
                    </div>

                    
                    <div class="tab-pane fade" id="transfers">
                        {% if transfers is empty %}
                            <p class="text-muted text-center py-4">Sin historial de fichajes.</p>
                        {% else %}
                            <div class="timeline position-relative ps-4 border-start ms-2">
                                {% for transfer in transfers %}
                                    <div class="mb-4 position-relative">
                                        <div class="position-absolute start-0 top-0 translate-middle-x bg-white border border-primary rounded-circle" style="width: 12px; height: 12px; left: -1px;"></div>
                                        <div class="h6 mb-1 text-primary">{% if transfer.date is not empty %}{{ transfer.date|date('d M Y') }}{% else %}<span class="text-muted fst-italic">Actualización</span>{% endif %}</div>
                                        <div class="d-flex align-items-center bg-light p-3 rounded">
                                            <div class="d-flex align-items-center text-muted">
                                                <img src="{{ transfer.teams.out.logo }}" width="30" class="me-2 rounded-circle border">
                                                {{ transfer.teams.out.name }}
                                            </div>
                                            <i class="fas fa-arrow-right mx-3 text-secondary"></i>
                                            <div class="d-flex align-items-center fw-bold">
                                                <img src="{{ transfer.teams.in.logo }}" width="30" class="me-2 rounded-circle border">
                                                {{ transfer.teams.in.name }}
                                            </div>
                                            
                                            <div class="ms-auto text-success fw-bold small">
                                                {{ transfer.type == 'Loan' ? 'Cedido' : (transfer.type == 'Free' ? 'Libre' : transfer.type) }}
                                            </div>
                                        </div>
                                    </div>
                                {% endfor %}
                            </div>
                        {% endif %}
                    </div>

                    
                    <div class="tab-pane fade" id="news">
                        {% if relatedNews is empty %}
                            <p class="text-muted text-center py-4">No hay noticias relacionadas con este jugador.</p>
                        {% else %}
                            <div class="row row-cols-1 row-cols-md-2 g-3">
                                {% for item in relatedNews %}
                                    <div class="col">
                                        <div class="card h-100 border-0 shadow-sm">
                                            {% if item.image %}
                                                <img src="{{ item.image }}" class="card-img-top" style="height: 150px; object-fit: cover;">
                                            {% endif %}
                                            <div class="card-body">
                                                <h6 class="card-title fw-bold">{{ item.title }}</h6>
                                                <p class="card-text small text-muted">{{ item.content|slice(0, 80) }}...</p>
                                                <button class="btn btn-sm btn-outline-primary" 
                                                    data-bs-toggle="modal" data-bs-target="#newsDetailModal"
                                                    data-news-id="{{ item.id }}"
                                                    data-news-title="{{ item.title }}"
                                                    data-news-content="{{ item.content }}"
                                                    data-news-image="{{ item.image }}"
                                                    data-news-date="{{ item.createdAt|date('d M, Y') }}">
                                                    Leer más
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                {% endfor %}
                            </div>
                        {% endif %}
                    </div>

                    
                    <div class="tab-pane fade" id="forum">
                        <div class="alert alert-info border-0 d-flex align-items-center">
                            <i class="fas fa-info-circle me-2 fs-4"></i>
                            <div>
                                <strong>Foro de Discusión</strong>
                                <div class="small">Comparte tu opinión sobre {{ player.player.name }}.</div>
                            </div>
                        </div>

                        
                        {% include 'review/_form.html.twig' with {'type': 'player', 'externalId': player.player.id} %}
                        {% include 'review/_list.html.twig' %}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
