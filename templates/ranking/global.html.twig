{% extends 'base.html.twig' %}

{% block title %}Estadísticas Globales{% endblock %}

{% block body %}
<div class="row align-items-center mb-4">
    <div class="col">
        <h1 class="mb-0 fw-bold">🌍 Estadísticas globales y Rankings</h1>
        <p class="text-muted">Resumen global de toda la actividad de valoraciones en la plataforma.</p>
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-4">
        <div class="card text-center text-white bg-primary mb-3 shadow-sm h-100">
            <div class="card-body d-flex flex-column justify-content-center">
                <h5 class="card-title fw-bold">Total de Valoraciones</h5>
                <h2 class="display-3 fw-bold mb-0">{{ totalReviews }}</h2>
                <small class="text-white-50">Reseñas publicadas</small>
            </div>
        </div>
    </div>
    <div class="col-md-8">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-dark text-white fw-bold">
                ⭐ Promedio de Puntuaciones por Categoría
            </div>
            <div class="card-body p-0">
                {% if averages|length > 0 %}
                    <ul class="list-group list-group-flush">
                    {% for avg in averages %}
                        <li class="list-group-item d-flex justify-content-between align-items-center py-3">
                            <span class="text-uppercase fw-bold text-muted">{{ avg.type }}</span>
                            <span class="badge bg-warning text-dark fs-6 rounded-pill">⭐ {{ avg.avg_rating|number_format(1) }}</span>
                        </li>
                    {% endfor %}
                    </ul>
                {% else %}
                    <div class="p-4 text-center text-muted">Aún no hay valoraciones en ninguna categoría.</div>
                {% endif %}
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-6 mb-4">
        <div class="card h-100 shadow-sm border-0">
            <div class="card-header bg-success text-white fw-bold">
                👟 Jugadores Más Valorados (Top 5)
            </div>
            <div class="card-body p-0">
                {% if topPlayers|length > 0 %}
                    <ul class="list-group list-group-flush">
                        {% for player in topPlayers %}
                            <li class="list-group-item d-flex align-items-center py-3">
                                {% if player.photo %}
                                    <img src="{{ player.photo }}" alt="{{ player.name }}" class="rounded-circle me-3 border" style="width: 48px; height: 48px; object-fit: cover;">
                                {% endif %}
                                <div class="flex-grow-1 fw-bold fs-5">{{ player.name }}</div>
                                <span class="badge bg-warning text-dark fs-6 rounded-pill shadow-sm">⭐ {{ player.avg_rating|number_format(1) }}</span>
                            </li>
                        {% endfor %}
                    </ul>
                {% else %}
                    <div class="p-5 text-center text-muted">
                        <i class="fs-1 text-light mb-2">👟</i><br>
                        Aún no hay jugadores valorados.
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
    <div class="col-md-6 mb-4">
        <div class="card h-100 shadow-sm border-0">
            <div class="card-header bg-danger text-white fw-bold">
                🛡️ Equipos Más Valorados (Top 5)
            </div>
            <div class="card-body p-0">
                {% if topTeams|length > 0 %}
                    <ul class="list-group list-group-flush">
                        {% for team in topTeams %}
                            <li class="list-group-item d-flex align-items-center py-3">
                                {% if team.photo %}
                                    <img src="{{ team.photo }}" alt="{{ team.name }}" class="me-3" style="width: 48px; height: 48px; object-fit: contain;">
                                {% endif %}
                                <div class="flex-grow-1 fw-bold fs-5">{{ team.name }}</div>
                                <span class="badge bg-warning text-dark fs-6 rounded-pill shadow-sm">⭐ {{ team.avg_rating|number_format(1) }}</span>
                            </li>
                        {% endfor %}
                    </ul>
                {% else %}
                    <div class="p-5 text-center text-muted">
                        <i class="fs-1 text-light mb-2">🛡️</i><br>
                        Aún no hay equipos valorados.
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>
</div>

<h3 class="mt-5 mb-4 fw-bold border-bottom pb-2">🏆 Rankings Globales (Por Puntos)</h3>
<div class="row">
    <div class="col-md-6 mb-4">
        <div class="card h-100 shadow-sm border-0">
            <div class="card-header bg-primary text-white fw-bold">
                👟 Top Jugadores Histórico
            </div>
            <div class="card-body p-0">
                {% if topRankedPlayers is defined and topRankedPlayers|length > 0 %}
                    <ul class="list-group list-group-flush">
                        {% for player in topRankedPlayers %}
                            <li class="list-group-item d-flex align-items-center py-3">
                                <div class="me-3 fw-bold fs-4 text-primary">#{{ loop.index }}</div>
                                {% if player.photo %}
                                    <img src="{{ player.photo }}" alt="{{ player.name }}" class="rounded-circle me-3 border" style="width: 48px; height: 48px; object-fit: cover;">
                                {% endif %}
                                <div class="flex-grow-1 fw-bold fs-5">{{ player.name }}</div>
                                <span class="badge bg-primary fs-6 rounded-pill shadow-sm">{{ player.points }} pts</span>
                            </li>
                        {% endfor %}
                    </ul>
                {% else %}
                    <div class="p-5 text-center text-muted">
                        <i class="fs-1 text-light mb-2">👟</i><br>
                        Nadie ha añadido jugadores a sus rankings aún.
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
    <div class="col-md-6 mb-4">
        <div class="card h-100 shadow-sm border-0">
            <div class="card-header bg-secondary text-white fw-bold">
                🛡️ Top Equipos Histórico
            </div>
            <div class="card-body p-0">
                {% if topRankedTeams is defined and topRankedTeams|length > 0 %}
                    <ul class="list-group list-group-flush">
                        {% for team in topRankedTeams %}
                            <li class="list-group-item d-flex align-items-center py-3">
                                <div class="me-3 fw-bold fs-4 text-secondary">#{{ loop.index }}</div>
                                {% if team.photo %}
                                    <img src="{{ team.photo }}" alt="{{ team.name }}" class="me-3" style="width: 48px; height: 48px; object-fit: contain;">
                                {% endif %}
                                <div class="flex-grow-1 fw-bold fs-5">{{ team.name }}</div>
                                <span class="badge bg-secondary fs-6 rounded-pill shadow-sm">{{ team.points }} pts</span>
                            </li>
                        {% endfor %}
                    </ul>
                {% else %}
                    <div class="p-5 text-center text-muted">
                        <i class="fs-1 text-light mb-2">🛡️</i><br>
                        Nadie ha añadido equipos a sus rankings aún.
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}
