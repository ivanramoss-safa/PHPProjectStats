{% extends 'base.html.twig' %}

{% block title %}Mi Perfil{% endblock %}

{% block body %}
    <div class="row align-items-center mb-4">
        <div class="col">
            <h1 class="mb-0">👤 Mi Perfil</h1>
            <p class="text-muted">Gestiona tu información y actividad.</p>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-body">
            <h5 class="card-title">Datos del Usuario</h5>
            <hr>
            <div class="row mb-3">
                <div class="col-md-3 fw-bold text-muted">Nombre:</div>
                <div class="col-md-9">{{ user.name }} {{ user.lastname }}</div>
            </div>
            <div class="row mb-3">
                <div class="col-md-3 fw-bold text-muted">Email:</div>
                <div class="col-md-9">{{ user.email }}</div>
            </div>
            <div class="row mb-3">
                <div class="col-md-3 fw-bold text-muted">Rol:</div>
                <div class="col-md-9">
                    {% if 'ROLE_ADMIN' in user.roles %}
                        <span class="badge bg-primary">Administrador</span>
                    {% else %}
                        <span class="badge bg-secondary">Usuario Normal</span>
                    {% endif %}
                </div>
            </div>
            
        </div>
    </div>

    <div class="row">
        <div class="col-md-6">
            <div class="card text-center mb-4">
                <div class="card-body">
                    <h5 class="card-title mb-3">🏅 Mis Rankings</h5>
                    <p class="card-text text-muted">Crea, edita y gestiona tus tops personalizados.</p>
                    <a href="{{ path('app_ranking_index') }}" class="btn btn-primary">Ir a Mis Rankings</a>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card text-center mb-4">
                <div class="card-body">
                    <h5 class="card-title mb-3">⚙️ Panel de Control</h5>
                    <p class="card-text text-muted">Modifica los apartados del sistema.</p>
                    {% if is_granted('ROLE_ADMIN') %}
                        <a href="{{ path('app_admin') }}" class="btn btn-info">Ir al Panel Admin</a>
                    {% else %}
                        <button class="btn btn-secondary" disabled>Acceso Denegado</button>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
{% endblock %}
