{% extends 'base.html.twig' %}

{% block title %}{{ fixture.teams.home.name }} vs {{ fixture.teams.away.name }} - Post-Match{% endblock %}

{% block body %}

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body text-center p-4">
        <div class="row align-items-center">
            
            <div class="col-4">
                <img src="{{ fixture.teams.home.logo }}" alt="{{ fixture.teams.home.name }}" class="mb-2" style="height: 80px;">
                <h4 class="fw-bold">{{ fixture.teams.home.name }}</h4>
            </div>
            
            
            <div class="col-4">
                {% if fixture.fixture.status.short == 'FT' or fixture.fixture.status.short == 'AET' or fixture.fixture.status.short == 'PEN' %}
                    <div class="display-4 fw-bold">{{ fixture.goals.home }} - {{ fixture.goals.away }}</div>
                    <div class="text-muted small">{{ fixture.fixture.status.long }}</div>
                {% elseif fixture.fixture.status.short == 'NS' %}
                    <div class="display-6 fw-bold">VS</div>
                    <div class="text-muted">{{ fixture.fixture.date|date('H:i') }}</div>
                {% else %}
                     <div class="display-4 fw-bold text-danger">{{ fixture.goals.home }} - {{ fixture.goals.away }}</div>
                     <span class="badge bg-danger animate-pulse">EN JUEGO - {{ fixture.fixture.status.elapsed }}'</span>
                {% endif %}
                <div class="small text-muted mt-2">
                    {{ fixture.league.name }} - {{ fixture.league.round }}
                </div>
            </div>
            
            
            <div class="col-4">
                <img src="{{ fixture.teams.away.logo }}" alt="{{ fixture.teams.away.name }}" class="mb-2" style="height: 80px;">
                <h4 class="fw-bold">{{ fixture.teams.away.name }}</h4>
            </div>
        </div>
        
        <hr>
        
        <div class="text-muted small">
            <i class="fas fa-calendar-alt me-1"></i> {{ fixture.fixture.date|date('d M Y') }} &nbsp;|&nbsp;
            <i class="fas fa-map-marker-alt me-1"></i> {{ fixture.fixture.venue.name }}, {{ fixture.fixture.venue.city }}
        </div>
        
        {% if averageRating is defined and averageRating > 0 %}
            <div class="d-flex justify-content-center align-items-center mt-3">
                <span class="text-warning me-2 fs-5">
                    {% for i in 1..5 %}
                        {% if i <= averageRating|round(0, 'floor') %}<i class="fas fa-star"></i>
                        {% elseif i - averageRating < 0.5 %}<i class="fas fa-star-half-alt"></i>
                        {% else %}<i class="far fa-star"></i>{% endif %}
                    {% endfor %}
                </span>
                <span class="fw-bold fs-5">({{ averageRating|number_format(1) }})</span>
            </div>
        {% endif %}
    </div>
</div>

<div class="row">
    
    <div class="col-lg-8">
        
        
        <ul class="nav nav-tabs mb-4 border-bottom-0" id="matchTabs" role="tablist">
            <li class="nav-item">
                <button class="nav-link active fw-bold" data-bs-toggle="tab" data-bs-target="#resumen">
                    📊 Resumen
                </button>
            </li>
            <li class="nav-item">
                <button class="nav-link fw-bold" data-bs-toggle="tab" data-bs-target="#alineaciones">
                    👕 Alineaciones
                </button>
            </li>
            <li class="nav-item">
                <button class="nav-link fw-bold" data-bs-toggle="tab" data-bs-target="#estadisticas">
                    📈 Estadísticas
                </button>
            </li>
            {% if relatedNews is not empty %}
            <li class="nav-item">
                <button class="nav-link fw-bold" data-bs-toggle="tab" data-bs-target="#noticias">
                    📰 Noticias
                </button>
            </li>
            {% endif %}
        </ul>

        <div class="tab-content" id="matchTabsContent">
            
            
            <div class="tab-pane fade show active" id="resumen">
                
                {% if prediction %}
                    <div class="card border-0 shadow-sm mb-4">
                        <div class="card-header bg-white fw-bold border-bottom-0"><i class="fas fa-magic me-2 text-primary"></i>Predicción Previa</div>
                        <div class="card-body">
                            <p class="mb-2"><strong>Pronóstico Inteligente:</strong> {{ prediction.predictions.advice }}</p>
                            <div class="progress mb-2 rounded-pill" style="height: 25px;">
                                <div class="progress-bar bg-success" style="width: {{ prediction.predictions.percent.home }};" title="Local: {{ prediction.predictions.percent.home }}">1: {{ prediction.predictions.percent.home }}</div>
                                <div class="progress-bar bg-secondary" style="width: {{ prediction.predictions.percent.draw }};" title="Empate: {{ prediction.predictions.percent.draw }}">X: {{ prediction.predictions.percent.draw }}</div>
                                <div class="progress-bar bg-primary" style="width: {{ prediction.predictions.percent.away }};" title="Visitante: {{ prediction.predictions.percent.away }}">2: {{ prediction.predictions.percent.away }}</div>
                            </div>
                        </div>
                    </div>
                {% endif %}

                {% if events is not empty %}
                    <div class="card border-0 shadow-sm">
                        <div class="card-header bg-white fw-bold border-bottom-0"><i class="fas fa-list-ul me-2 text-primary"></i>Cronología del Partido</div>
                        <div class="card-body p-0">
                            <ul class="list-group list-group-flush">
                                {% for event in events %}
                                    <li class="list-group-item d-flex align-items-center py-3">
                                        <div class="fw-bold me-3 text-center" style="width: 45px;">
                                            <span class="fs-5">{{ event.time.elapsed }}'</span>
                                            {% if event.time.extra %}<span class="d-block small text-muted">+{{ event.time.extra }}'</span>{% endif %}
                                        </div>
                                        <div class="me-3">
                                            {% if event.team.id == fixture.teams.home.id %}
                                                <img src="{{ fixture.teams.home.logo }}" width="30" class="rounded-circle shadow-sm border">
                                            {% else %}
                                                <img src="{{ fixture.teams.away.logo }}" width="30" class="rounded-circle shadow-sm border">
                                            {% endif %}
                                        </div>
                                        <div class="flex-grow-1 border-start ps-3">
                                            {% if event.type == 'Goal' %}
                                                <i class="fas fa-futbol text-success me-1"></i> <strong class="fs-6">{{ event.player.name }}</strong>
                                                <span class="badge bg-light text-success border border-success ms-2">{{ event.detail }}</span>
                                                {% if event.assist.name %} <div class="text-muted small ms-4">Asistencia: {{ event.assist.name }}</div>{% endif %}
                                            {% elseif event.type == 'Card' %}
                                                <i class="fas fa-square {{ event.detail == 'Yellow Card' ? 'text-warning' : 'text-danger' }} border border-dark rounded-1 me-1"></i> <strong class="fs-6">{{ event.player.name }}</strong>
                                                <span class="text-muted small ms-2">({{ event.detail }})</span>
                                            {% elseif event.type == 'subst' %}
                                                <i class="fas fa-exchange-alt text-primary me-1"></i>
                                                <strong class="text-success"><i class="fas fa-arrow-up small"></i> {{ event.player.name }}</strong>
                                                <div class="text-danger small ms-4 mt-1"><i class="fas fa-arrow-down small"></i> {{ event.assist.name }}</div>
                                            {% else %}
                                                <span class="badge bg-secondary">{{ event.detail }}</span> <strong>{{ event.player.name }}</strong>
                                            {% endif %}
                                        </div>
                                    </li>
                                {% endfor %}
                            </ul>
                        </div>
                    </div>
                {% else %}
                    <div class="alert alert-light text-center border-0 shadow-sm">Vuelve más tarde para ver la línea de tiempo.</div>
                {% endif %}
            </div>

            
            <div class="tab-pane fade" id="alineaciones">
                {% if lineups is not empty and lineups|length == 2 %}
                    <div class="row g-4">
                        
                        <div class="col-md-6">
                            <div class="card border-0 shadow-sm h-100">
                                <div class="card-header bg-white text-center border-bottom-0 pt-4">
                                    <img src="{{ lineups[0].team.logo }}" width="60" class="mb-2 rounded-circle shadow-sm border">
                                    <h5 class="fw-bold mb-1">{{ lineups[0].team.name }}</h5>
                                    <span class="badge bg-dark rounded-pill shadow-sm px-3 py-2">{{ lineups[0].formation }}</span>
                                </div>
                                <div class="card-body p-0">
                                    <h6 class="bg-light p-2 border-top border-bottom fw-bold text-center m-0 text-muted text-uppercase" style="letter-spacing: 1px; font-size: 0.8rem;">Entrenador</h6>
                                    <p class="text-center py-2 m-0 fw-bold"><i class="fas fa-user-tie me-2 text-primary"></i>{{ lineups[0].coach.name }}</p>

                                    <h6 class="bg-light p-2 border-top border-bottom fw-bold text-center m-0 text-muted text-uppercase" style="letter-spacing: 1px; font-size: 0.8rem;">Titulares</h6>
                                    <ul class="list-group list-group-flush">
                                        {% for item in lineups[0].startXI %}
                                            <li class="list-group-item d-flex align-items-center px-3 py-2 border-light">
                                                <span class="badge bg-secondary me-3 rounded-circle shadow-sm" style="width: 25px; height: 25px; display: flex; align-items: center; justify-content: center;">{{ item.player.number }}</span>
                                                <span class="text-muted small fw-bold me-3 text-center" style="width: 20px;">{{ item.player.pos }}</span>
                                                <a href="{{ path('player_show', {id: item.player.id}) }}" class="text-dark text-decoration-none fw-bold flex-grow-1">{{ item.player.name }}</a>
                                            </li>
                                        {% endfor %}
                                    </ul>

                                    <h6 class="bg-light p-2 border-top border-bottom fw-bold text-center m-0 text-muted text-uppercase" style="letter-spacing: 1px; font-size: 0.8rem;">Suplentes</h6>
                                    <ul class="list-group list-group-flush mb-3">
                                        {% for item in lineups[0].substitutes %}
                                            <li class="list-group-item d-flex align-items-center px-3 py-2 border-light">
                                                <span class="badge bg-light text-dark border me-3 rounded-circle" style="width: 25px; height: 25px; display: flex; align-items: center; justify-content: center;">{{ item.player.number }}</span>
                                                <span class="text-muted small fw-bold me-3 text-center" style="width: 20px;">{{ item.player.pos }}</span>
                                                <a href="{{ path('player_show', {id: item.player.id}) }}" class="text-secondary text-decoration-none flex-grow-1">{{ item.player.name }}</a>
                                            </li>
                                        {% endfor %}
                                    </ul>
                                </div>
                            </div>
                        </div>

                        
                        <div class="col-md-6">
                             <div class="card border-0 shadow-sm h-100">
                                <div class="card-header bg-white text-center border-bottom-0 pt-4">
                                    <img src="{{ lineups[1].team.logo }}" width="60" class="mb-2 rounded-circle shadow-sm border">
                                    <h5 class="fw-bold mb-1">{{ lineups[1].team.name }}</h5>
                                    <span class="badge bg-dark rounded-pill shadow-sm px-3 py-2">{{ lineups[1].formation }}</span>
                                </div>
                                <div class="card-body p-0">
                                    <h6 class="bg-light p-2 border-top border-bottom fw-bold text-center m-0 text-muted text-uppercase" style="letter-spacing: 1px; font-size: 0.8rem;">Entrenador</h6>
                                    <p class="text-center py-2 m-0 fw-bold"><i class="fas fa-user-tie me-2 text-primary"></i>{{ lineups[1].coach.name }}</p>

                                    <h6 class="bg-light p-2 border-top border-bottom fw-bold text-center m-0 text-muted text-uppercase" style="letter-spacing: 1px; font-size: 0.8rem;">Titulares</h6>
                                    <ul class="list-group list-group-flush">
                                        {% for item in lineups[1].startXI %}
                                            <li class="list-group-item d-flex align-items-center px-3 py-2 border-light">
                                                <span class="badge bg-secondary me-3 rounded-circle shadow-sm" style="width: 25px; height: 25px; display: flex; align-items: center; justify-content: center;">{{ item.player.number }}</span>
                                                <span class="text-muted small fw-bold me-3 text-center" style="width: 20px;">{{ item.player.pos }}</span>
                                                <a href="{{ path('player_show', {id: item.player.id}) }}" class="text-dark text-decoration-none fw-bold flex-grow-1">{{ item.player.name }}</a>
                                            </li>
                                        {% endfor %}
                                    </ul>

                                    <h6 class="bg-light p-2 border-top border-bottom fw-bold text-center m-0 text-muted text-uppercase" style="letter-spacing: 1px; font-size: 0.8rem;">Suplentes</h6>
                                    <ul class="list-group list-group-flush mb-3">
                                        {% for item in lineups[1].substitutes %}
                                            <li class="list-group-item d-flex align-items-center px-3 py-2 border-light">
                                                <span class="badge bg-light text-dark border me-3 rounded-circle" style="width: 25px; height: 25px; display: flex; align-items: center; justify-content: center;">{{ item.player.number }}</span>
                                                <span class="text-muted small fw-bold me-3 text-center" style="width: 20px;">{{ item.player.pos }}</span>
                                                <a href="{{ path('player_show', {id: item.player.id}) }}" class="text-secondary text-decoration-none flex-grow-1">{{ item.player.name }}</a>
                                            </li>
                                        {% endfor %}
                                    </ul>
                                </div>
                            </div>
                        </div>
                    </div>
                {% else %}
                    <div class="alert alert-light text-center border-0 shadow-sm">Alineaciones no confirmadas o no disponibles.</div>
                {% endif %}
            </div>

            
            <div class="tab-pane fade" id="estadisticas">
                {% if statistics is not empty and statistics|length == 2 %}
                    <div class="card border-0 shadow-sm p-4">
                        <div class="row align-items-center mb-4 text-center pb-3 border-bottom">
                            <div class="col-4"><img src="{{ statistics[0].team.logo }}" width="60" class="rounded shadow-sm"></div>
                            <div class="col-4 fw-bold text-primary text-uppercase" style="letter-spacing: 1px;">Estadísticas del Partido</div>
                            <div class="col-4"><img src="{{ statistics[1].team.logo }}" width="60" class="rounded shadow-sm"></div>
                        </div>

                        {% for i in 0..(statistics[0].statistics|length - 1) %}
                            {% set statName = statistics[0].statistics[i].type %}
                            {% set valHome = statistics[0].statistics[i].value|default(0) %}
                            {% set valAway = statistics[1].statistics[i].value|default(0) %}
                            
                            
                            {% set numHome = (valHome is iterable) ? 0 : valHome|replace({'%': ''})|number_format(0, '.', '') %}
                            {% set numAway = (valAway is iterable) ? 0 : valAway|replace({'%': ''})|number_format(0, '.', '') %}
                            {% set total = numHome + numAway %}
                            {% set wHome = total > 0 ? (numHome / total * 100) : 50 %}
                            {% set wAway = total > 0 ? (numAway / total * 100) : 50 %}

                            <div class="mb-4">
                                <div class="d-flex justify-content-between mb-2 small fw-bold">
                                    <span class="badge bg-light text-dark border {% if numHome > numAway %}border-success{% endif %} fs-6" style="min-width: 45px;">{{ valHome ?? '-' }}</span>
                                    <span class="text-muted text-uppercase">{{ statName }}</span>
                                    <span class="badge bg-light text-dark border {% if numAway > numHome %}border-success{% endif %} fs-6" style="min-width: 45px;">{{ valAway ?? '-' }}</span>
                                </div>
                                <div class="progress shadow-sm bg-light" style="height: 8px;">
                                    <div class="progress-bar {% if numHome > numAway %}bg-success{% else %}bg-secondary{% endif %}" style="width: {{ wHome }}%"></div>
                                    <div class="progress-bar {% if numAway > numHome %}bg-success{% else %}bg-secondary{% endif %}" style="width: {{ wAway }}%"></div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% else %}
                    <div class="alert alert-light text-center border-0 shadow-sm">Estadísticas no registradas aún.</div>
                {% endif %}
            </div>

            
            {% if relatedNews is not empty %}
            <div class="tab-pane fade" id="noticias">
                <div class="row row-cols-1 row-cols-md-2 g-3">
                    {% for item in relatedNews %}
                        <div class="col">
                            <div class="card h-100 border-0 shadow-sm">
                                {% if item.image %}
                                    <img src="{{ item.image }}" class="card-img-top" style="height: 150px; object-fit: cover;">
                                {% endif %}
                                <div class="card-body">
                                    <h6 class="card-title fw-bold">{{ item.title }}</h6>
                                    <p class="card-text small text-muted">{{ item.content|slice(0, 80) }}...</p>
                                    <button class="btn btn-sm btn-outline-primary" 
                                            data-bs-toggle="modal" data-bs-target="#newsDetailModal"
                                            data-news-id="{{ item.id }}"
                                            data-news-title="{{ item.title }}"
                                            data-news-content="{{ item.content }}"
                                            data-news-image="{{ item.image }}">
                                        Leer más
                                    </button>
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </div>
            {% endif %}

        </div>
    </div>

    
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-primary text-white fw-bold">
                <i class="fas fa-comments me-2"></i>Post-Match Thread
            </div>
            <div class="card-body">
                <p class="small text-muted">Debate sobre las jugadas polémicas, el MVP y el resultado.</p>
                
                
                {% include 'review/_form.html.twig' with {'type': 'fixture', 'externalId': fixture.fixture.id} %}
                
                <hr>
                
                <div class="reviews-list">
                    {% include 'review/_list.html.twig' %}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
