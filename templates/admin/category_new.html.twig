{% extends 'base.html.twig' %}

{% block title %}Nueva Categoría{% endblock %}

{% block body %}
    <h1 class="mb-4">Nueva Categoría</h1>

    
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label }}">{{ message }}</div>
        {% endfor %}
    {% endfor %}

    <div class="card">
        <div class="card-body">
            <form method="post">
                <div class="mb-3">
                    <label for="name" class="form-label">Nombre de la categoría *</label>
                    <input type="text"
                           class="form-control"
                           id="name"
                           name="name"
                           required
                           placeholder="Ej: Jugadores LaLiga">
                </div>

                <div class="mb-3">
                    <label for="type" class="form-label">Tipo *</label>
                    <select class="form-select" id="type" name="type" required>
                        <option value="">Selecciona un tipo</option>
                        <option value="player">Jugador</option>
                        <option value="team">Equipo</option>
                        <option value="league">Liga</option>
                        <option value="stadium">Estadio</option>
                        <option value="coach">Entrenador</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label for="description" class="form-label">Descripción</label>
                    <textarea class="form-control"
                              id="description"
                              name="description"
                              rows="3"
                              placeholder="Descripción opcional"></textarea>
                </div>

                <hr>

                <hr>

                <h5>Elementos de la Categoría</h5>
                <p class="text-muted"><small>Busca y añade elementos según el tipo elegido arriba.</small></p>

                
                <div class="mb-4">
                    <div class="d-flex mb-2">
                        <button type="button" class="btn btn-outline-primary btn-sm me-2 btn-open-search-modal" id="dynamicSearchBtn" data-type="" disabled>
                            🔍 Buscar Elementos
                        </button>
                        <small id="searchHelperText" class="text-danger mt-1">Primero debes seleccionar el tipo de categoría.</small>
                    </div>

                    <div id="dynamicIds-chips" data-role="dynamic-chips" class="p-3 border rounded bg-light" style="min-height: 60px;">
                        <span class="text-muted">Ningún elemento añadido.</span>
                    </div>

                
                <input type="hidden" name="items" id="dynamicIds-hidden" data-role="dynamic-hidden" value="">
                
            </div>

                <div class="mt-3">
                    <button type="submit" class="btn btn-primary">💾 Crear Categoría</button>
                    <a href="{{ path('app_admin') }}" class="btn btn-secondary">Cancelar</a>
                </div>
            </form>
        </div>
    </div>

    <script>
        (function() {
            const typeSelect = document.getElementById('type');
            const searchBtn = document.getElementById('dynamicSearchBtn');
            const helperText = document.getElementById('searchHelperText');

            const typeMapping = {
                'player': 'players',
                'team': 'teams',
                'league': 'leagues',
                'stadium': 'venues',
                'coach': 'coaches'
            };

            const dynamicChips = document.querySelector('[data-role="dynamic-chips"]');
            const dynamicHidden = document.querySelector('[data-role="dynamic-hidden"]');

            if (typeSelect) {
                typeSelect.addEventListener('change', (e) => {
                    if (window.newsSearch) {
                        window.newsSearch.selectedItems = {
                            'players': [], 'teams': [], 'leagues': [], 'coaches': [], 'venues': [], 'fixtures': []
                        };
                    }
                    
                    if (dynamicChips) dynamicChips.innerHTML = '<span class="text-muted">Ningún elemento añadido.</span>';
                    if (dynamicHidden) dynamicHidden.value = '';

                    const val = e.target.value;
                    if (val && typeMapping[val]) {
                        const searchType = typeMapping[val];
                        if (searchBtn) searchBtn.dataset.type = searchType;
                        
                        if (dynamicChips) dynamicChips.id = `${searchType}Ids-chips`;
                        if (dynamicHidden) dynamicHidden.id = `${searchType}Ids-hidden`;
                        
                        if (searchBtn) searchBtn.disabled = false;
                        if (helperText) helperText.style.display = 'none';
                    } else {
                        if (searchBtn) searchBtn.disabled = true;
                        if (helperText) helperText.style.display = 'block';
                    }
                });
            }
        })();
    </script>
    
    
    {% include 'admin/news/_search_modal.html.twig' %}
    <script src="{{ asset('js/news-associations.js') }}"></script>
{% endblock %}
