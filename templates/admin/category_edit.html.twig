{% extends 'base.html.twig' %}

{% block title %}Editar Categoría{% endblock %}

{% block body %}
    <h1 class="mb-4">Editar Categoría: {{ category.name }}</h1>

    <div class="card">
        <div class="card-body">
            <form method="post">
                <div class="mb-3">
                    <label for="name" class="form-label">Nombre *</label>
                    <input type="text"
                           class="form-control"
                           id="name"
                           name="name"
                           value="{{ category.name }}"
                           required>
                </div>

                <div class="mb-3">
                    <label class="form-label">Tipo</label>
                    <input type="text"
                           class="form-control"
                           value="{{ category.type }}"
                           disabled>
                    <small class="text-muted">El tipo no se puede cambiar después de crear la categoría</small>
                </div>

                <div class="mb-3">
                    <label for="description" class="form-label">Descripción</label>
                    <textarea class="form-control"
                              id="description"
                              name="description"
                              rows="3">{{ category.description }}</textarea>
                </div>

                <hr>

                <h5>Elementos de la Categoría</h5>

                
                <div class="mb-4 mt-3">
                    <div class="d-flex mb-2">
                        <button type="button" class="btn btn-outline-primary btn-sm me-2 btn-open-search-modal" id="dynamicSearchBtn" data-type="" disabled>
                            🔍 Añadir Elementos
                        </button>
                    </div>

                    <div id="dynamicIds-chips" class="p-3 border rounded bg-light" style="min-height: 60px;">
                        <span class="text-muted">Cargando elementos...</span>
                    </div>

                    
                    <input type="hidden" name="items" id="dynamicIds-hidden" value="{{ currentItems|join(',') }}">

                    
                    <div style="display: none;">
                        <input type="hidden" id="playersIds-hidden" value="">
                        <input type="hidden" id="teamsIds-hidden" value="">
                        <input type="hidden" id="leaguesIds-hidden" value="">
                        <input type="hidden" id="coachesIds-hidden" value="">
                        <input type="hidden" id="venuesIds-hidden" value="">
                        <input type="hidden" id="fixturesIds-hidden" value="">
                    </div>
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn btn-primary">💾 Guardar Cambios</button>
                    <a href="{{ path('app_admin') }}" class="btn btn-secondary">Cancelar</a>
                </div>
            </form>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
             const categoryType = '{{ category.type }}';
             const currentItemsData = {{ currentItemsObjects|json_encode|raw }};

             const searchBtn = document.getElementById('dynamicSearchBtn');
             const chipsContainer = document.getElementById('dynamicIds-chips');
             const hiddenInput = document.getElementById('dynamicIds-hidden');

             const typeMapping = {
                'player': 'players',
                'team': 'teams',
                'league': 'leagues',
                'stadium': 'venues',
                'coach': 'coaches'
             };

             const searchType = typeMapping[categoryType];

             if (searchType) {
                 searchBtn.dataset.type = searchType;
                 searchBtn.disabled = false;

                 chipsContainer.id = `${searchType}Ids-chips`;
                 hiddenInput.id = `${searchType}Ids-hidden`;

                 const fillChips = () => {
                     if (window.newsSearch) {
                         window.newsSearch.selectedItems[searchType] = currentItemsData.map(item => ({
                             id: parseInt(item.id),
                             name: item.name,
                             photo: item.photo
                         }));
                         window.newsSearch.renderChips(searchType);
                         window.newsSearch.updateHiddenInput(searchType);
                     } else {
                         setTimeout(fillChips, 50);
                     }
                 };
                 fillChips();
             }
        });
    </script>

    
    {% include 'admin/news/_search_modal.html.twig' %}
    <script src="{{ asset('js/news-associations.js') }}"></script>
{% endblock %}
